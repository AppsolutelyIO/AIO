{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "NODE_ENV=development tsx build.ts",
        "build": "NODE_ENV=production tsx build.ts",
        "prod": "NODE_ENV=production tsx build.ts",
        "production": "NODE_ENV=production tsx build.ts",
        "build:tabler": "vite build --config themes/tabler/vite.config.ts",
        "dev:tabler": "vite --config themes/tabler/vite.config.ts --port 5179",
        "build:page-builder": "vite build --config vite.pagebuilder.config.ts",
        "dev:page-builder": "vite --config vite.pagebuilder.config.ts --port 5178",
        "type-check": "tsc --noEmit",
        "type-check:aio": "tsc --noEmit -p tsconfig.aio.json",
        "type-check:pagebuilder": "tsc --project tsconfig.pagebuilder.json --noEmit",
        "type-check:all": "npm run type-check && npm run type-check:aio && npm run type-check:pagebuilder",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:scss": "stylelint 'resources/page-builder/**/*.scss' 'themes/june/**/*.scss' --allow-empty-input",
        "lint:scss:fix": "stylelint 'resources/page-builder/**/*.scss' 'themes/june/**/*.scss' --fix --allow-empty-input",
        "lint:all": "npm run lint && npm run lint:scss",
        "lint:all:fix": "npm run lint:fix && npm run lint:scss:fix",
        "format": "prettier --write '**/*.{scss,css,ts,js,json,md}'",
        "format:check": "prettier --check '**/*.{scss,css,ts,js,json,md}'",
        "format:blade": "blade-formatter --write --no-php-syntax-check '**/*.blade.php'",
        "test:frontend": "vitest run",
        "test:frontend:watch": "vitest",
        "test:frontend:coverage": "vitest run --coverage",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/node": "^25.5.0",
        "@types/nprogress": "^0.2.3",
        "apexcharts": "^5.10.3",
        "axios": "^1.7.4",
        "blade-formatter": "^1.44.2",
        "bootstrap-colorpicker": "^3.4.0",
        "bootstrap-duallistbox": "^3.0.9",
        "bootstrap-validator": "^0.11.9",
        "devbridge-autocomplete": "^1.5.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.6.0",
        "fontawesome-iconpicker": "^3.2.0",
        "glob": "^13.0.6",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jquery-nestable": "^0.8.0",
        "jquery-pjax": "^2.0.1",
        "jquery.initialize": "^1.3.2",
        "jquery.inputmask": "^3.3.4",
        "jsdom": "^29.0.0",
        "jstree": "^3.3.17",
        "laravel-vite-plugin": "^2.1.0",
        "lint-staged": "^16.2.4",
        "lodash": "^4.17.23",
        "pc-bootstrap4-datetimepicker": "^4.17.51",
        "prettier": "^3.6.2",
        "rtlcss": "^4.3.0",
        "sass": "^1.98.0",
        "sortablejs": "^1.15.7",
        "stylelint": "^17.4.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "tailwindcss": "^4.2.1",
        "tinymce": "^5.10.9",
        "tinymce-i18n": "^23.12.19",
        "toastr": "^2.1.4",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vditor": "^3.11.2",
        "vite": "^7.3.1",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.1.0",
        "@tabler/core": "^1.4.0",
        "admin-lte": "^3.2.0",
        "bootstrap-icons": "^1.13.1",
        "grapesjs": "^0.22.13",
        "nprogress": "^0.2.0",
        "sweetalert2": "^9.17.4",
        "swiper": "^12.1.2",
        "vanilla-lazyload": "^19.1.3"
    },
    "lint-staged": {
        "*.php": [
            "../site/vendor/bin/pint"
        ],
        "*.blade.php": [
            "blade-formatter --write --no-php-syntax-check"
        ],
        "*.scss": [
            "prettier --write",
            "stylelint --fix"
        ],
        "*.{ts,js}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{css,json,md}": [
            "prettier --write"
        ]
    }
}
