{
    "name": "appsolutely/aio",
    "description": "AI-powered application framework for Laravel — admin dashboard, CMS, e-commerce, and production-ready APIs out of the box",
    "type": "library",
    "keywords": [
        "appsolutely",
        "aio",
        "laravel",
        "admin",
        "dashboard",
        "cms",
        "e-commerce",
        "ai",
        "api"
    ],
    "homepage": "https://appsolutely.io",
    "license": "MIT",
    "authors": [
        {
            "name": "Appsolutely",
            "homepage": "https://appsolutely.io"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "spatie/eloquent-sortable": "^4.0|^5.0",
        "doctrine/dbal": "^3.0|^4.0",
        "openspout/openspout": "^5.4"
    },
    "require-dev": {
        "laravel/dusk": "^8.0",
        "phpstan/phpstan": "^1.0|^2.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Appsolutely\\AIO\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Appsolutely\\AIO\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Appsolutely\\AIO\\AdminServiceProvider"
            ]
        }
    }
}
