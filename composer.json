{
    "name": "appsolutely/aio",
    "description": "AI-powered application framework for Laravel — admin dashboard, CMS, e-commerce, and production-ready APIs out of the box",
    "type": "library",
    "keywords": [
        "appsolutely",
        "aio",
        "laravel",
        "admin",
        "dashboard",
        "cms",
        "e-commerce",
        "ai",
        "api"
    ],
    "homepage": "https://appsolutely.io",
    "license": "MIT",
    "authors": [
        {
            "name": "Appsolutely",
            "homepage": "https://appsolutely.io"
        }
    ],
    "require": {
        "php": "^8.2",
        "deepseek-php/deepseek-php-client": "^2.0",
        "fahlisaputra/laravel-minify": "^1.2",
        "intervention/image": "^3.0",
        "kalnoy/nestedset": "^6.0",
        "laravel/ai": "^0.3.0",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^4.0",
        "mcamara/laravel-localization": "^2.3",
        "openai-php/laravel": "^0.19.0",
        "openspout/openspout": "^5.4",
        "prettus/l5-repository": "^3.0",
        "qirolab/laravel-themer": "^2.4",
        "spatie/eloquent-sortable": "^5.0",
        "spatie/laravel-data": "4.*",
        "spatie/laravel-responsecache": "^8.0"
    },
    "require-dev": {
        "laravel/dusk": "^8.0",
        "larastan/larastan": "^3.0",
        "phpunit/phpunit": "^12.0",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6|^2.0",
        "orchestra/testbench": "^10.0",
        "laravel/sanctum": "^4.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Appsolutely\\AIO\\": "src/"
        },
        "files": [
            "src/Support/helpers.php",
            "src/Helpers/helpers.php",
            "src/Helpers/admin_ui_helpers.php",
            "src/Helpers/app_config_helpers.php",
            "src/Helpers/data_helpers.php",
            "src/Helpers/grid_helpers.php",
            "src/Helpers/http_helpers.php",
            "src/Helpers/logging_helpers.php",
            "src/Helpers/markdown_helpers.php",
            "src/Helpers/site_config_helpers.php",
            "src/Helpers/theme_helpers.php",
            "src/Helpers/timezone_helpers.php",
            "src/Helpers/translation_helpers.php",
            "src/Helpers/url_helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Models\\": "tests/Stubs/",
            "Database\\Factories\\": "tests/Stubs/",
            "Appsolutely\\AIO\\Tests\\": "tests/",
            "Appsolutely\\AIO\\Database\\Factories\\": "database/factories/",
            "Appsolutely\\AIO\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Appsolutely\\AIO\\AdminServiceProvider",
                "Appsolutely\\AIO\\AIOServiceProvider"
            ]
        }
    }
}
