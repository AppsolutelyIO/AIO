{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["vite/client", "node"],
        "baseUrl": ".",
        "paths": {
            "@aio/*": ["./resources/assets/aio/js/*"],
            "@adminlte/*": ["./resources/assets/adminlte/js/*"],
            "@resources/*": ["./resources/*"]
        }
    },
    "include": ["resources/page-builder/assets/**/*.ts", "types/**/*.d.ts", "build.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "vendor", "resources/dist", "resources/pre-dist"]
}
