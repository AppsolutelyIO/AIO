            "displayOptionsDefinition": {
                "logo": { "type": "boolean", "label": "Show Logo", "default": true },
                "cta": {
                    "type": "object",
                    "label": "Call To Action",
                    "fields": {
                        "text": { "type": "text", "label": "Button Text", "default": "Get Started" },
                        "url": { "type": "url", "label": "Button URL", "default": "/contact" }
                    }
                }
            },
            "styles": ["default"]
        },
