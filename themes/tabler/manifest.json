{
    "version": "1.0.0",
    "description": "Tabler theme manifest - clean, modern admin-style public site using Tabler UI",
    "templates": {
        "anchor": {
            "label": "Anchor Navigation",
            "description": "Sticky navigation bar linking to sections below",
            "component": "App\\Livewire\\Anchor",
            "view": "anchor-navigation",
            "displayOptions": {
                "cta_text": "Get Started",
                "cta_url": "/contact",
                "cta_icon": ""
            },
            "displayOptionsDefinition": {
                "cta_text": { "type": "text", "label": "CTA Text", "default": "Get Started" },
                "cta_url": { "type": "url", "label": "CTA URL", "default": "/contact" },
                "cta_icon": { "type": "text", "label": "CTA Icon (class name)", "default": "" }
            },
            "styles": ["default"]
        },
        "article-list": {
            "label": "Article List",
            "description": "Display a list of articles with pagination",
            "component": "App\\Livewire\\ArticleList",
            "view": "article-list",
            "displayOptions": {
                "title": "Latest Articles",
                "subtitle": "Stay updated with our latest news",
                "show_featured_image": true,
                "show_excerpt": true,
                "show_author": true,
                "show_date": true,
                "show_read_more": true,
                "read_more_text": "Read More",
                "layout": "grid"
            },
            "displayOptionsDefinition": {
                "title": { "type": "text", "label": "Title", "default": "Latest Articles" },
                "subtitle": { "type": "textarea", "label": "Subtitle", "default": "Stay updated with our latest news" },
                "show_featured_image": { "type": "boolean", "label": "Show Featured Image", "default": true },
                "show_excerpt": { "type": "boolean", "label": "Show Excerpt", "default": true },
                "show_author": { "type": "boolean", "label": "Show Author", "default": true },
                "show_date": { "type": "boolean", "label": "Show Date", "default": true },
                "show_read_more": { "type": "boolean", "label": "Show Read More", "default": true },
                "read_more_text": { "type": "text", "label": "Read More Text", "default": "Read More" },
                "layout": {
                    "type": "select",
                    "label": "Layout",
                    "options": [
                        { "value": "grid", "label": "Grid" },
                        { "value": "list", "label": "List" }
                    ],
                    "default": "grid"
                }
            },
            "styles": ["default"]
        },
        "dynamic-form": {
            "label": "Dynamic Form",
            "description": "Dynamic form with validation and submission",
            "component": "App\\Livewire\\DynamicForm",
            "view": "dynamic-form",
            "displayOptions": {
                "title": "Contact Us",
                "subtitle": "We'd love to hear from you",
                "description": "Fill out the form below and we'll get back to you shortly.",
                "submit_text": "Send Message",
                "success_title": "Thank You!",
                "success_message": "Your message has been sent. We'll be in touch soon.",
                "layout": "form",
                "theme": "default",
                "columns": 1,
                "redirect": "",
                "redirect_url": "",
                "redirect_after_submit": ""
            },
            "displayOptionsDefinition": {
                "title": { "type": "text", "label": "Title", "default": "Contact Us" },
                "subtitle": { "type": "text", "label": "Subtitle", "default": "We'd love to hear from you" },
                "description": {
                    "type": "textarea",
                    "label": "Description",
                    "default": "Fill out the form below and we'll get back to you shortly."
                },
                "submit_text": { "type": "text", "label": "Submit Button Text", "default": "Send Message" },
                "success_title": { "type": "text", "label": "Success Title", "default": "Thank You!" },
                "success_message": {
                    "type": "textarea",
                    "label": "Success Message",
                    "default": "Your message has been sent. We'll be in touch soon."
                },
                "layout": {
                    "type": "select",
                    "label": "Layout",
                    "options": [{ "value": "form", "label": "Form" }],
                    "default": "form"
                },
                "theme": {
                    "type": "select",
                    "label": "Theme",
                    "options": [{ "value": "default", "label": "Default" }],
                    "default": "default"
                },
                "columns": { "type": "number", "label": "Columns", "min": 1, "max": 3, "default": 1 },
                "redirect": {
                    "type": "select",
                    "label": "Redirect mode",
                    "options": [
                        { "value": "", "label": "None" },
                        { "value": "force", "label": "Force (alias URL)" }
                    ],
                    "default": ""
                },
                "redirect_url": { "type": "text", "label": "Redirect URL path", "default": "" },
                "redirect_after_submit": { "type": "url", "label": "Redirect After Submit", "default": "" }
            },
            "styles": ["default", "interactive", "content"]
        },
        "features": {
            "label": "Features",
            "description": "Feature highlight cards in a Tabler grid layout",
            "component": "App\\Livewire\\GeneralBlock",
            "view": "features",
            "displayOptions": {
                "title": "",
                "subtitle": "",
                "descriptions": [],
                "features": [
                    { "type": "image", "url": "https://placehold.co/400x300", "title": "", "subtitle": "", "link": "" },
                    { "type": "image", "url": "https://placehold.co/400x300", "title": "", "subtitle": "", "link": "" },
                    { "type": "image", "url": "https://placehold.co/400x300", "title": "", "subtitle": "", "link": "" }
                ]
            },
            "displayOptionsDefinition": {
                "title": { "type": "text", "label": "Title", "default": "" },
                "subtitle": { "type": "textarea", "label": "Subtitle", "default": "" },
                "descriptions": {
                    "type": "table",
                    "label": "Descriptions",
                    "fields": { "text": { "type": "textarea", "label": "Text" } },
                    "default": []
                },
                "features": {
                    "type": "table",
                    "label": "Features",
                    "fields": {
                        "type": {
                            "type": "select",
                            "label": "Type",
                            "options": [{ "value": "image", "label": "Image" }],
                            "default": "image"
                        },
                        "url": { "type": "image", "label": "Image", "default": "" },
                        "title": { "type": "text", "label": "Title", "default": "" },
                        "subtitle": { "type": "text", "label": "Subtitle", "default": "" },
                        "link": { "type": "url", "label": "Link", "default": "" }
                    },
                    "default": []
                }
            },
            "styles": ["default", "equal-columns", "fullscreen", "alternating-rows"]
        },
        "footer": {
            "label": "Footer",
            "description": "Site footer with menus, contact info, and social links",
            "component": "App\\Livewire\\Footer",
            "view": "footer",
            "displayOptions": {
                "logo": true,
                "contact": {
                    "enabled": true,
                    "phone": "",
                    "email": "",
                    "address": ""
                },
                "newsletter": {
                    "enabled": true,
                    "title": "Subscribe to our newsletter",
                    "text": "Get the latest updates and offers"
                },
                "company_name": "",
                "address": "",
                "email": "",
                "copyright": {
                    "text": "© 2025 Your Company. All rights reserved."
                }
            },
            "displayOptionsDefinition": {
                "logo": { "type": "boolean", "label": "Show Logo", "default": true },
                "contact": {
                    "type": "object",
                    "label": "Contact",
                    "fields": {
                        "enabled": { "type": "boolean", "label": "Enabled", "default": true },
                        "phone": { "type": "text", "label": "Phone", "default": "" },
                        "email": { "type": "email", "label": "Email", "default": "" },
                        "address": { "type": "text", "label": "Address", "default": "" }
                    }
                },
                "newsletter": {
                    "type": "object",
                    "label": "Newsletter",
                    "fields": {
                        "enabled": { "type": "boolean", "label": "Enabled", "default": true },
                        "title": { "type": "text", "label": "Title", "default": "Subscribe to our newsletter" },
                        "text": { "type": "text", "label": "Text", "default": "Get the latest updates and offers" }
                    }
                },
                "company_name": { "type": "text", "label": "Company Name", "default": "" },
                "address": { "type": "text", "label": "Address", "default": "" },
                "email": { "type": "email", "label": "Email", "default": "" },
                "copyright": {
                    "type": "object",
                    "label": "Copyright",
                    "fields": {
                        "text": {
                            "type": "text",
                            "label": "Text",
                            "default": "© 2025 Your Company. All rights reserved."
                        }
                    }
                }
            },
            "styles": ["default"]
        },
        "header": {
            "label": "Header",
            "description": "Site header with Tabler navbar and navigation",
            "component": "App\\Livewire\\Header",
            "view": "header",
