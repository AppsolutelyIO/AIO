                        "subtitle": "Slide Subtitle 1"
                    },
                    {
                        "type": "image",
                        "link": "/",
                        "url": "https://placehold.co/1200x800",
                        "title": "Slide Title 2",
                        "subtitle": "Slide Subtitle 2"
